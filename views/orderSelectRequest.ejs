                    }
                ]
            }
        });
        const selected = document.getElementById('practitioner-select').value;
            selectedPractitioner = pieterPractionerDetails;
    }
    
    function handleLocation() {
        const locationDetails = JSON.stringify({
            "resourceType": "Location",
            "status": "active",
            "name": "Washington, DC metro area",
            "identifier": [
                {
                    "value": "B1-S.F2"
                },
                {
                    "value": "B1-S.F2.1.00"
                }
            ]
        });
        const selected = document.getElementById('location-select').value;
        selectedLocation = locationDetails;
    }

    function createOrderSelectInput(){
        selectedStartDate = document.getElementById("startDate").value;
        selectedEndDate = document.getElementById("endDate").value;
        let requestStructure;
        if(selectedRequestType == "service"){
            fetch('/read-order-select-service-sample-structure', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    requestStructure = data.data;
                    requestStructure.hookInstance = 'from-bridge-application-'+Date.now();
                    alert(JSON.stringify(requestStructure));
                }
            })
            .catch(error => {
                console.error('Error:', error);
            });
        }
        else if(selectedRequestType == "medication"){
            fetch('/read-order-select-medication-sample-structure', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    requestStructure = data.data;
                    alert(JSON.stringify(requestStructure));
                }
            })
            .catch(error => {
                console.error('Error:', error);
            });
        }
      }

    function disableForRequestTypeSelection(){
        selectedService = null;
        selectedMedication = null;
        selectedStartDate = null;
        selectedEndDate = null;
        selectedQuantity = null;

        document.getElementById('medication-select').setAttribute("disabled", "disabled");
        document.getElementById('service-select').setAttribute("disabled", "disabled");
        document.getElementById('startDate').setAttribute("disabled", "disabled");
        document.getElementById('endDate').setAttribute("disabled", "disabled");
        document.getElementById('quantity').setAttribute("disabled", "disabled");
        document.getElementById('submit').setAttribute("disabled", "disabled");
        
    }

    function prepareForMedOrServiceSelection(){
        selectedStartDate = null;
        selectedEndDate = null;
        selectedQuantity = null;
        document.getElementById('submit').removeAttribute("disabled");
        document.getElementById('startDate').removeAttribute("disabled")
        document.getElementById('endDate').removeAttribute("disabled")
        document.getElementById('quantity').removeAttribute("disabled")
    }

</script>