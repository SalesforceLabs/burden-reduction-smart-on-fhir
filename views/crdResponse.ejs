<%- include('header') -%>

    <div class="cardContainer">
        <h2 class="font-weight-bold">Coverage Requirement Discovery Responses</h2>
        <% cards.forEach(function(card, index) { const action=systemActions[index]; // Get corresponding systemAction
            const modalId='modal-' + index; // Unique ID for each modal %>
            <div class="col-md-4">
                <div class="card mb-3 <%= card.indicator %>">
                    <div class="card-header">
                        <h5 class="card-title">
                            <%= card.source.label %>
                        </h5>
                    </div>
                    <div class="card-body">
                        <p class="card-text">
                            <%= card.summary %>
                        </p>
                        <a href="<%= card.links.url %>" class="btn btn-primary">
                            <%= card.links.label %>
                        </a>
                        <button type="button" class="btn btn-info mt-2" data-bs-toggle="modal"
                            data-bs-target="#<%= modalId %>">
                            View System Action
                        </button>
                    </div>
                </div>
            </div>

            <!-- Modal for System Action -->
            <div class="modal fade" id="<%= modalId %>" tabindex="-1" aria-labelledby="modalLabel-<%= index %>"
                aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="modalLabel-<%= index %>">System Action Details</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <% if (action) { %>
                                <h6 class="card-subtitle mb-2 text-muted">System Action: <%= action.type %>
                                </h6>
                                <p class="card-text">
                                    <%= action.description %>
                                </p>
                                <p class="card-text"><strong>Resource Type:</strong>
                                    <%= action.resource.resourceType %>
                                </p>

                                <% if (action.resource.resourceType==='MedicationRequest' ) { %>
                                    <p class="card-text"><strong>Medication:</strong>
                                        <%= action.resource.entryInfo.medicationCodeableConcept.text %>
                                    </p>
                                    <p class="card-text"><strong>Effective Period:</strong>
                                        <%= action.resource.entryInfo.effectiveDosePeriod.start %> to <%=
                                                action.resource.entryInfo.effectiveDosePeriod.end %>
                                    </p>
                                    <% } %>

                                        <p class="card-text"><strong>Status:</strong>
                                            <%= action.resource.entryInfo.status %>
                                        </p>
                                        <p class="card-text"><strong>Intent:</strong>
                                            <%= action.resource.entryInfo.intent %>
                                        </p>

                                        <% if (action.resource.extension) { %>
                                            <hr>
                                            <h6 class="card-subtitle mb-2 text-muted">Extensions</h6>
                                            <% Object.keys(action.resource.extension).forEach(function(key) { %>
                                                <p class="card-text"><strong>
                                                        <%= key %>:
                                                    </strong>
                                                    <%= action.resource.extension[key].value !== undefined ?
                                                        action.resource.extension[key].value :
                                                        action.resource.extension[key].valueString !== undefined ?
                                                        action.resource.extension[key].valueString : 
                                                        action.resource.extension[key].valueDate !== undefined ?
                                                        action.resource.extension[key].valueDate :
                                                        action.resource.extension[key].valueContactPoint !== undefined ?
                                                        action.resource.extension[key].valueContactPoint : null%>
                                                </p>
                                                <% }); %>
                                                    <% } %>
                                                        <% } %>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
            <% }); %>
    </div>

    <%- include('footer') -%>