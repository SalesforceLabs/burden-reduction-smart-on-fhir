<div class="text-center center-div" id="providerLogin">
    <div class="container w-25 border py-5">
        <div class="title pb-5">
            <h2 class="font-weight-bold"><%= loginHeader %></h2>
            <span><%= loginSubHeader %></span>
        </div>
        <form action="#" class="pt-2">
            <div class="form-group">
                <small class="form-text text-muted text-left">Enter Username</small>
                <input type="text" class="form-control" placeholder="username" name="username">
            </div>
            <div class="form-group pt-3">
                <small class="form-text text-muted text-left">Enter Password</small>
                <input type="text" class="form-control" placeholder="password" name="password">
            </div>
            <div class="form-group pt-3">
                <small class="form-text text-muted text-left">Enter Consumer Key</small>
                <input type="text" class="form-control" placeholder="consumer-key" name="consumer-key">
            </div>
            <div class="form-group pt-3">
                <small class="form-text text-muted text-left">Enter Cosumer Secret</small>
                <input type="text" class="form-control" placeholder="consumer-secret" name="cosumer-secret">
            </div>
            <div class="pt-3">
                <button type="submit" class="btn btn-success rounded-pill">Login</button>
            </div>
        </form>
    </div>
</div>
