<%- include('header') -%>
<div class="text-center center-div" id="baseLogin">
    <div class="container w-45 border py-5">
        <div class="title pb-5">
            <h1 class="heading-style">Welcome to the DTR Portal</h1>
            <span>Please provide the Questionnaire Id</span>
        </div>
        <form id="inputForm" class="pt-2">
            <label for="userInput">Input:</label>
            <input type="text" id="userInput" name="userInput" onchange="handleChange(event)" required>
            <button type="submit">Submit</button>
        </form>

        <div id="spinner" class="spinner" style="display: none;"></div>
        <div id="backdrop" class="backdrop" style="display: none;"></div>
    </div>
    </div>
<%- include('footer') -%>
<script>
    const form = document.getElementById('inputForm');
    const spinner = document.getElementById('spinner');
    const contextId = "<%= contextId %>";
    const dtrContextId = "<%= dtrContextId %>";

    document.addEventListener("DOMContentLoaded", function () {
        if (contextId) {
            const userInputElement = document.getElementById('userInput');
            userInputElement.value = contextId;
            form.dispatchEvent(new SubmitEvent("submit",{ bubbles: true, cancelable: true }));
        }
    });

    function handleChange(event) {
        contextId = event.target.value;
    }

    form.addEventListener('submit', async (event) => {
        event.preventDefault();
        
        spinner.style.display = 'block';
        backdrop.style.display = 'block';

        const userInput = document.getElementById('userInput').value;

        try {
            const response = await fetch('/fetchQuestionnaire', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ userInput })
            });

            const resultPage = await response.text();

            // Replace the current page with the response
            document.body.innerHTML = resultPage;

            await populateResponse();
        } catch (error) {
            console.error('Error:', error);
            alert('Something went wrong!');
        } finally {
            spinner.style.display = 'none';
            backdrop.style.display = 'none';
        }
    });

    async function populateResponse() {
        const response = await fetch('/fetchQuestionnaireResponse', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                questionnaireId : contextId,
            })
        });

        const data = await response.json();

        if(response.ok && data.success){
            if(data.data){
                data.data.forEach(item => {
                    const question = document.getElementById(item.questionId);
                    if(question){
                        question.value = item.response;
                    }
                });
            }
        }
    }
</script>

<script>
    function showStep(stepIndex) {
        document.querySelectorAll('.step').forEach((step, index) => {
            step.classList.toggle('active', index === stepIndex);
        });
    }

    async function handleSubmitQuestionnaire() {

        const questionInputs = document.querySelectorAll('input[id^="question-"]');
        const questionList = Array.from(questionInputs).map(input => ({
            questionId: input.id,         // Get the input's id
            response: input.value.trim(),
            developeName: input.getAttribute("data-developer-name") // Get the input's value
        }));

        try {
            const response = await fetch('/handleQuestionnaireSubmit', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ 
                    "questionnaireId" : contextId,
                    "response" : questionList
                 })
            });

            const resultPage = await response.text();
            if(dtrContextId) {
                window.location.href = `/dtrResponse?contextId=${dtrContextId}`;
            } else {
                 window.location.href = `/dtrResponse`;
            }
        } catch (error) {
            alert('Something went wrong!');
        } 
    }
</script>

