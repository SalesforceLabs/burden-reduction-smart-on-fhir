<%- include('header') -%>

<div class="text-center center-div" id="providerLogin">
    <div class="container w-25 border py-5">
        <div class="title pb-5">
            <h2 class="font-weight-bold">Welcome to Utilization Management Portal</h2>
            <span>Please Configure Provider and Payer</span>
        </div>
        <form action="/provider-login" method="POST" class="pt-2">
            <div class="pt-3">
                <button type="submit" class="btn btn-success rounded-pill">Login to Provider</button>
            </div>
        </form>
        <form action="/payer-login" method="POST" class="pt-2">
            <div class="pt-3">
                <button type="submit" class="btn btn-success rounded-pill">Login to Payer</button>
            </div>
        </form>
        <div class="pt-3">
            <button id="oauthLoginBtn" class="btn btn-primary rounded-pill">Login with Salesforce</button>
        </div>
    </div>
</div>

<%- include('footer') -%>
<script>
    //redirects page to oauth URL using window
    document.getElementById('oauthLoginBtn').addEventListener('click', function() {
        const clientId = '<%= process.env.SALESFORCE_CLIENT_ID %>';
        const redirectUri = '<%= process.env.SALESFORCE_REDIRECT_URI %>';
        const authUrl = '<%= process.env.SALESFORCE_TOKEN_URL %>';
        const scope = 'api full';

        const oauthUrl = `${authUrl}?response_type=token&client_id=${clientId}&redirect_uri=${encodeURIComponent(redirectUri)}&scope=${encodeURIComponent(scope)}`;
        window.location.href = oauthUrl;
    });
</script>